<!-- ══════════════════════════════════════
     PROCESS
══════════════════════════════════════ -->
<section id="process">
  <div class="sec-label rv">Workflow</div>
  <h2 class="sec-heading rv">The <em>Process</em></h2>

  <div class="process-steps">
    <div class="proc-step rv">
      <div class="proc-num">01</div>
      <div class="proc-name">Discovery</div>
      <div class="proc-desc">Deep dive into your vision, goals, references, and audience. Understanding the story before touching a timeline.</div>
      <div class="proc-day">1–2 Days</div>
    </div>
    <div class="proc-step rv" style="transition-delay:.1s">
      <div class="proc-num">02</div>
      <div class="proc-name">Asset Review</div>
      <div class="proc-desc">Cataloguing all footage, audio, graphics. Building a strategy, structure, and edit roadmap.</div>
      <div class="proc-day">1–3 Days</div>
    </div>
    <div class="proc-step rv" style="transition-delay:.2s">
      <div class="proc-num">03</div>
      <div class="proc-name">First Cut</div>
      <div class="proc-desc">Polished first assembly delivered. Pacing, narrative flow, and visual rhythm tested — ready for review.</div>
      <div class="proc-day">3–7 Days</div>
    </div>
    <div class="proc-step rv" style="transition-delay:.3s">
      <div class="proc-num">04</div>
      <div class="proc-name">Refinement</div>
      <div class="proc-desc">Iterative revisions, color grade, sound mix, motion graphics. Every detail sharpened to perfection.</div>
      <div class="proc-day">2–4 Days</div>
    </div>
    <div class="proc-step rv" style="transition-delay:.4s">
      <div class="proc-num">05</div>
      <div class="proc-name">Delivery</div>
      <div class="proc-desc">Master files in all formats — broadcast, web, social. Project archive. You own everything.</div>
      <div class="proc-day">1 Day</div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     TOOLS
══════════════════════════════════════ -->
<section id="tools">
  <div class="sec-label rv">Arsenal</div>
