<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>THE EDITOR — Visual Storyteller</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Bebas+Neue&family=Inter:wght@300;400&display=swap" rel="stylesheet"/>

<style>
/* ─────────────────────────────────────────
   ROOT & RESET
───────────────────────────────────────── */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  /* Core Palette */
  --black:    #080406;
  --black2:   #0e080b;
  --black3:   #130b0e;
  --red:      #8b0000;
  --red-deep: #5a0000;
  --red-hot:  #c0001a;
  --red-glow: #ff1a1a;
  --gold:     #c9a84c;
  --gold-lt:  #e8c76a;
  --gold-bright:#f5d780;
  --gold-dim: #7a6020;
  --cream:    #fff4db;
  --text:     #f1e7d4;
  --text2:    #ffffff;
  --border-r: rgba(139,0,0,.35);
  --border-g: rgba(201,168,76,.2);
  --glow-r:   0 0 20px rgba(192,0,26,.5),0 0 60px rgba(139,0,0,.25);
  --glow-g:   0 0 20px rgba(201,168,76,.4),0 0 60px rgba(201,168,76,.15);
}
html{scroll-behavior:smooth;cursor:none}
body{
  background:var(--black);
  color:var(--text);
  font-family:'Cormorant Garamond',serif;
  overflow-x:hidden;
}
::selection{background:var(--red);color:var(--gold-bright)}

/* ─────────────────────────────────────────
   GRAIN + VIGNETTE
───────────────────────────────────────── */
#grain{
  position:fixed;inset:0;z-index:999;pointer-events:none;
  opacity:.55;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)' opacity='0.06'/%3E%3C/svg%3E");
  animation:grainAnim .35s steps(3) infinite;
}
@keyframes grainAnim{
  0%{transform:translate(0,0)}25%{transform:translate(-3%,2%)}
  50%{transform:translate(2%,-3%)}75%{transform:translate(-1%,3%)}100%{transform:translate(3%,-1%)}
}
#vignette{
  position:fixed;inset:0;z-index:998;pointer-events:none;
  background:radial-gradient(ellipse at center,transparent 40%,rgba(5,0,3,.85) 100%);
}

/* SCANLINES */
#scanlines{
  position:fixed;inset:0;z-index:997;pointer-events:none;
  background:repeating-linear-gradient(
    0deg,rgba(0,0,0,.03) 0px,rgba(0,0,0,.03) 1px,transparent 1px,transparent 3px
  );
}

/* ─────────────────────────────────────────
   CUSTOM CURSOR
───────────────────────────────────────── */
#cur{
  position:fixed;z-index:99999;pointer-events:none;
  width:10px;height:10px;border-radius:50%;
  background:var(--gold);
  box-shadow:var(--glow-g);
  transform:translate(-50%,-50%);
  transition:transform .08s,background .2s,width .2s,height .2s;
  mix-blend-mode:normal;
}
#cur-ring{
  position:fixed;z-index:99998;pointer-events:none;
  width:40px;height:40px;
  border:1px solid rgba(201,168,76,.6);
  border-radius:50%;
  transform:translate(-50%,-50%);
  transition:width .25s,height .25s,border-color .25s;
}
.cur-hover #cur{width:16px;height:16px;background:var(--red-hot);box-shadow:var(--glow-r)}
.cur-hover #cur-ring{width:56px;height:56px;border-color:rgba(192,0,26,.5)}

/* ─────────────────────────────────────────
   SCROLLBAR
───────────────────────────────────────── */
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:var(--black)}
::-webkit-scrollbar-thumb{background:var(--red);border-radius:2px}

/* ─────────────────────────────────────────
   NAV
───────────────────────────────────────── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;align-items:center;justify-content:space-between;
  padding:28px 60px;
  transition:padding .4s,background .4s,border-color .4s;
  border-bottom:1px solid transparent;
}
nav.stuck{
  padding:16px 60px;
  background:rgba(8,4,6,.92);
  backdrop-filter:blur(24px);
  border-bottom-color:var(--border-r);
}
.logo{
  font-family:'Cinzel',serif;font-weight:900;font-size:1.15rem;
  letter-spacing:.3em;color:var(--gold);text-decoration:none;
  text-transform:uppercase;
  text-shadow:0 0 30px rgba(201,168,76,.4);
  transition:text-shadow .3s;
}
.logo:hover{text-shadow:var(--glow-g)}
.logo em{color:var(--red-hot);font-style:normal}

.nav-links{display:flex;gap:44px;list-style:none}
.nav-links a{
  font-family:'Inter',sans-serif;font-size:.68rem;font-weight:300;
  letter-spacing:.25em;color:var(--text2);text-decoration:none;text-transform:uppercase;
  transition:color .3s;position:relative;
}
.nav-links a::after{
  content:'';position:absolute;bottom:-5px;left:0;width:0;height:1px;
  background:var(--gold);box-shadow:var(--glow-g);transition:width .35s;
}
.nav-links a:hover{color:var(--gold)}
.nav-links a:hover::after{width:100%}

.nav-hire{
  font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;
  padding:11px 28px;border:1px solid var(--gold-dim);color:var(--gold);
  text-decoration:none;text-transform:uppercase;cursor:none;
  transition:all .35s;position:relative;overflow:hidden;
}
.nav-hire::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,var(--red-deep),var(--red));
  transform:scaleX(0);transform-origin:right;transition:transform .35s;z-index:-1;
}
.nav-hire:hover{border-color:var(--red-hot);color:var(--gold-bright);box-shadow:var(--glow-r)}
.nav-hire:hover::before{transform:scaleX(1);transform-origin:left}

/* ─────────────────────────────────────────
   HERO
───────────────────────────────────────── */
#hero{
  position:relative;min-height:100vh;
  display:flex;flex-direction:column;justify-content:flex-end;
  overflow:hidden;
}

/* animated film strip background */
.hero-film{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 70% at 60% 40%, rgba(90,0,0,.45) 0%, transparent 70%),
    radial-gradient(ellipse 50% 60% at 20% 80%, rgba(50,0,0,.3) 0%, transparent 60%),
    linear-gradient(170deg,#080406 0%,#100508 40%,#180808 70%,#0a0406 100%);
}

/* diagonal red accent bar */
.hero-bar{
  position:absolute;top:0;left:0;right:0;height:4px;
  background:linear-gradient(90deg,transparent,var(--red-hot),var(--gold),var(--red-hot),transparent);
  box-shadow:0 0 30px var(--red-hot),0 0 80px rgba(139,0,0,.5);
}

/* floating film-frame lines */
.hero-frames{position:absolute;inset:0;pointer-events:none}
.hero-frames::before{
  content:'';position:absolute;top:0;bottom:0;left:0;width:72px;
  background:
    repeating-linear-gradient(
      180deg,
      var(--black) 0px,var(--black) 18px,
      rgba(20,5,5,.8) 18px,rgba(20,5,5,.8) 80px
    );
  border-right:1px solid var(--border-r);opacity:.7;
}
.hero-frames::after{
  content:'';position:absolute;top:0;bottom:0;right:0;width:72px;
  background:
    repeating-linear-gradient(
      180deg,
      var(--black) 0px,var(--black) 18px,
      rgba(20,5,5,.8) 18px,rgba(20,5,5,.8) 80px
    );
  border-left:1px solid var(--border-r);opacity:.7;
}

.hero-content{
  position:relative;z-index:10;
  padding:0 120px 80px;
  max-width:1300px;
}

.hero-eyebrow{
  display:flex;align-items:center;gap:20px;margin-bottom:36px;
  opacity:0;animation:riseUp .9s .2s cubic-bezier(.16,1,.3,1) forwards;
}
.eyebrow-line{width:60px;height:1px;background:linear-gradient(90deg,var(--red-hot),var(--gold));box-shadow:0 0 10px var(--red)}
.eyebrow-text{
  font-family:'Inter',sans-serif;font-size:.65rem;font-weight:300;
  letter-spacing:.35em;color:var(--gold);text-transform:uppercase;
}
.eyebrow-dot{width:5px;height:5px;border-radius:50%;background:var(--red-hot);box-shadow:var(--glow-r);animation:blink 1.5s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

.hero-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(5rem,13vw,14rem);
  line-height:.88;letter-spacing:.02em;
  color:var(--cream);margin-bottom:8px;
  opacity:0;animation:riseUp 1s .4s cubic-bezier(.16,1,.3,1) forwards;
}
.hero-title .red-word{
  color:var(--red-hot);
  text-shadow:0 0 40px rgba(192,0,26,.5),0 0 100px rgba(139,0,0,.3);
  -webkit-text-stroke:1px rgba(255,100,100,.2);
}
.hero-title .gold-outline{
  -webkit-text-stroke:1px var(--gold-dim);
  color:transparent;
  text-shadow:none;
}

.hero-sub{
  font-family:'Cormorant Garamond',serif;font-weight:300;font-style:italic;
  font-size:clamp(1.1rem,2.5vw,1.8rem);
  color:var(--text2);letter-spacing:.12em;
  margin-bottom:52px;
  opacity:0;animation:riseUp .9s .6s cubic-bezier(.16,1,.3,1) forwards;
}
.hero-sub span{color:var(--gold);font-style:normal;font-weight:400}

.hero-actions{
  display:flex;align-items:center;gap:32px;flex-wrap:wrap;
  opacity:0;animation:riseUp .9s .8s cubic-bezier(.16,1,.3,1) forwards;
}
.btn-reel{
  font-family:'Cinzel',serif;font-size:.75rem;letter-spacing:.2em;
  padding:18px 52px;
  background:linear-gradient(135deg,var(--red-deep) 0%,var(--red) 50%,var(--red-deep) 100%);
  background-size:200% 100%;
  color:var(--gold-bright);border:1px solid var(--red-hot);cursor:none;
  text-decoration:none;text-transform:uppercase;
  transition:all .4s;
  box-shadow:var(--glow-r),inset 0 1px 0 rgba(255,255,255,.05);
}
.btn-reel:hover{
  background-position:100% 0;
  box-shadow:0 0 50px rgba(192,0,26,.7),0 0 100px rgba(139,0,0,.4);
  transform:translateY(-2px);
}
.btn-works{
  font-family:'Inter',sans-serif;font-size:.65rem;letter-spacing:.3em;
  color:var(--gold);text-decoration:none;text-transform:uppercase;
  cursor:none;display:flex;align-items:center;gap:10px;
  transition:color .3s;border-bottom:1px solid var(--gold-dim);padding-bottom:3px;
}
.btn-works::after{content:'↓';font-size:1rem;transition:transform .3s}
.btn-works:hover{color:var(--gold-bright)}
.btn-works:hover::after{transform:translateY(4px)}

/* hero stats strip */
.hero-stats{
  position:absolute;right:120px;bottom:80px;
  display:flex;flex-direction:column;gap:28px;z-index:10;
  opacity:0;animation:riseUp .9s 1s cubic-bezier(.16,1,.3,1) forwards;
}
.h-stat{text-align:right}
.h-stat-num{
  font-family:'Bebas Neue',sans-serif;font-size:2.8rem;line-height:1;
  color:var(--gold);text-shadow:var(--glow-g);
}
.h-stat-num span{font-size:1.4rem;color:var(--red-hot)}
.h-stat-lbl{
  font-family:'Inter',sans-serif;font-size:.6rem;letter-spacing:.25em;
  color:var(--text2);text-transform:uppercase;
}

/* scrolling indicator */
.scroll-ind{
  position:absolute;bottom:40px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;z-index:10;
  opacity:0;animation:fadeIn .8s 1.4s forwards;
}
.scroll-ind span{
  font-family:'Inter',sans-serif;font-size:.58rem;letter-spacing:.3em;
  color:var(--text2);text-transform:uppercase;
}
.scroll-ind-bar{
  width:1px;height:60px;background:linear-gradient(180deg,var(--gold),transparent);
  position:relative;overflow:hidden;
}
.scroll-ind-bar::after{
  content:'';position:absolute;top:-100%;left:0;width:100%;height:100%;
  background:var(--gold-bright);animation:scrollDown 1.8s ease-in-out infinite;
}
@keyframes scrollDown{from{top:-100%}to{top:100%}}

@keyframes riseUp{from{opacity:0;transform:translateY(50px)}to{opacity:1;transform:none}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

/* ─────────────────────────────────────────
   FEATURED WORKS — HOMEPAGE
───────────────────────────────────────── */
#featured{
  background:var(--black2);
  padding:0;position:relative;z-index:10;
}

.featured-header{
  padding:100px 120px 60px;
  display:flex;align-items:flex-end;justify-content:space-between;
  border-bottom:1px solid var(--border-r);
}
.featured-title-block{}
.featured-eyebrow{
  font-family:'Inter',sans-serif;font-size:.63rem;letter-spacing:.35em;
  color:var(--red-hot);text-transform:uppercase;margin-bottom:16px;
  display:flex;align-items:center;gap:12px;
}
.featured-eyebrow::before{content:'';width:30px;height:1px;background:var(--red-hot)}
.featured-heading{
  font-family:'Cinzel',serif;font-weight:700;font-size:clamp(2rem,4vw,3.5rem);
  color:var(--cream);letter-spacing:.05em;line-height:1.1;
}
.featured-heading em{
  font-style:italic;color:var(--gold);
  text-shadow:0 0 40px rgba(201,168,76,.3);
}
.featured-view-all{
  font-family:'Inter',sans-serif;font-size:.63rem;letter-spacing:.25em;
  color:var(--gold-dim);text-decoration:none;text-transform:uppercase;
  border-bottom:1px solid var(--gold-dim);padding-bottom:3px;
  cursor:none;transition:color .3s,border-color .3s;
}
.featured-view-all:hover{color:var(--gold);border-color:var(--gold)}

/* BIG FEATURED PIECE */
.work-hero{
  display:grid;grid-template-columns:1fr 1fr;
  border-bottom:1px solid var(--border-r);
}
.work-hero-visual{
  position:relative;aspect-ratio:16/10;overflow:hidden;cursor:none;
}
.work-hero-visual .thumb{
  position:absolute;inset:0;transition:transform .8s cubic-bezier(.25,.46,.45,.94);
}
.work-hero-visual:hover .thumb{transform:scale(1.06)}
.thumb-1{background: url("images/Trailer.png") center/cover no-repeat}  

.work-hero-visual::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent 60%,var(--black2));
  pointer-events:none;
}
/* play button overlay */
.play-over{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  z-index:5;opacity:0;transition:opacity .4s;
}
.work-hero-visual:hover .play-over{opacity:0}
.play-circle{
  width:72px;height:72px;border-radius:50%;
  border:1.5px solid var(--gold);
  display:flex;align-items:center;justify-content:center;
  background:rgba(10,0,5,.6);backdrop-filter:blur(8px);
  box-shadow:var(--glow-g);
}
.play-circle svg{width:22px;height:22px;fill:var(--gold);margin-left:4px}

.work-hero-info{
  padding:60px 80px;display:flex;flex-direction:column;justify-content:center;
  background:var(--black3);border-left:1px solid var(--border-r);
}
.work-cat{
  font-family:'Inter',sans-serif;font-size:.62rem;letter-spacing:.3em;
  color:var(--red-hot);text-transform:uppercase;margin-bottom:20px;
  display:flex;align-items:center;gap:10px;
}
.work-cat::before{content:'';width:20px;height:1px;background:var(--red-hot)}
.work-hero-title{
  font-family:'Cinzel',serif;font-weight:700;
  font-size:clamp(1.8rem,3vw,3rem);
  color:var(--cream);line-height:1.15;margin-bottom:24px;letter-spacing:.05em;
}
.work-hero-title span{color:var(--gold)}
.work-hero-desc{
  font-size:1.1rem;font-weight:300;color:var(--text2);line-height:1.9;
  margin-bottom:36px;max-width:380px;
}
.work-tags{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:40px}
.work-tag{
  font-family:'Inter',sans-serif;font-size:.58rem;letter-spacing:.2em;
  padding:6px 14px;border:1px solid var(--border-r);color:var(--text2);
  text-transform:uppercase;
}
.work-link{
  font-family:'Cinzel',serif;font-size:.9rem;letter-spacing:.2em;
  color:var(--gold);text-decoration:none;text-transform:uppercase;cursor:none;
  display:inline-flex;align-items:center;gap:12px;
  border-bottom:1px solid var(--gold-dim);padding-bottom:4px;
  transition:all .3s;width:fit-content;
}
.work-link::after{content:'→';transition:transform .3s}
.work-link:hover{color:var(--gold-bright);border-color:var(--gold)}
.work-link:hover::after{transform:translateX(6px)}

/* GRID WORKS */
.works-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  border-top:1px solid var(--border-r);
}
.work-cell{
  position:relative;overflow:hidden;cursor:none;
  border-right:1px solid var(--border-r);
}
.work-cell:last-child,.work-cell:nth-child(3n){border-right:none}
.work-cell-inner{
  position:relative;aspect-ratio:16/9;overflow:hidden;
}

.work-cell-thumb{
  position:absolute;inset:0;
  transition:transform .7s cubic-bezier(.25,.46,.45,.94);
}
.work-cell:hover .work-cell-thumb{transform:scale(1.08)}

.work-cell-thumb2{
  position:absolute;inset:0;
  transition:transform .7s cubic-bezier(.25,.46,.45,.94);
}
.work-cell:hover .work-cell-thumb2{background: url("images/dreamsycnxnep.png") center/cover no-repeat}
.work-cell-inner2{
  position:relative;aspect-ratio:4/3;overflow:hidden;
}
/* thumb color schemes */
.t1{background: url("images/Teaser.png") center/cover no-repeat}
.t2{background: url("images/brand.png") center/cover no-repeat}
.t3{background: url("images/ffxinbam.png") center/cover no-repeat}
.t4{background: url("images/main.png") center/cover no-repeat}
.t5{background: url("images/trip.png") center/cover no-repeat}

/* deco shapes inside thumbs */
.thumb-deco{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  opacity: .0;transition:opacity .4s;
}
.thumb-deco svg{width:60%;height:60%;color:var(--gold)}

.work-cell-overlay{
  position:absolute;inset:0;
  background:linear-gradient(0deg,rgba(5,0,3,.95) 0%,rgba(5,0,3,.3) 50%,transparent 100%);
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:28px;
  transform:translateY(12px);opacity:1;
  transition:all .4s cubic-bezier(.25,.46,.45,.94);
}
.work-cell:hover .work-cell-overlay{opacity:1;transform:none}
.cell-cat{
  font-family:'Inter',sans-serif;font-size:.5rem;letter-spacing:.25em;
  color:var(--red-hot);text-transform:uppercase;margin-bottom:6px;
}
.cell-title{
  font-family:'Cinzel',serif;font-size:1rem;font-weight:600;
  color:var(--cream);letter-spacing:.08em;margin-bottom:10px;
}
.cell-arrow{
  font-family:'Inter',sans-serif;font-size:.5rem;letter-spacing:.2em;
  color:var(--gold);text-transform:uppercase;display:flex;align-items:center;gap:8px;
}
.cell-arrow::after{content:'→';font-size:.9rem}

/* number label */
.work-cell-num{
  position:absolute;top:20px;left:20px;z-index:5;
  font-family:'Bebas Neue',sans-serif;font-size:1.8rem;
  color:rgba(255,255,255,.06);
  transition:color .3s;
}
.work-cell:hover .work-cell-num{color:rgba(201,168,76,.15)}

/* 2-column bottom row */
.works-grid-b{
  display:grid;grid-template-columns:2fr 1fr;
  border-top:1px solid var(--border-r);
}
.work-cell-wide .work-cell-inner{aspect-ratio:21/9}
.work-cell-mid .work-cell-inner{aspect-ratio:16/9}
.work-cell-mid2 .work-cell-inner{aspect-ratio:4/3}
/* ─────────────────────────────────────────
   TICKER
───────────────────────────────────────── */
.ticker{
  background:linear-gradient(90deg,var(--red-deep),var(--red),var(--red-deep));
  border-top:1px solid var(--red-hot);border-bottom:1px solid var(--red-hot);
  padding:14px 0;overflow:hidden;
  box-shadow:0 0 40px rgba(139,0,0,.4);
}
.ticker-track{
  display:flex;width:max-content;
  animation:tick 25s linear infinite;
}
.tick-item{
  font-family:'Cinzel',serif;font-size:.65rem;font-weight:600;
  letter-spacing:.3em;color:var(--gold-bright);text-transform:uppercase;
  padding:0 50px;white-space:nowrap;
}
.tick-item::after{content:'◆';margin-left:50px;color:rgba(255,215,100,.4)}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ─────────────────────────────────────────
   SERVICES
───────────────────────────────────────── */
#services{
  background:var(--black);
  padding:120px 120px;
  position:relative;z-index:10;
}
.sec-label{
  font-family:'Inter',sans-serif;font-size:.62rem;letter-spacing:.35em;
  color:var(--red-hot);text-transform:uppercase;
  display:flex;align-items:center;gap:14px;margin-bottom:20px;
}
.sec-label::before{content:'◆';font-size:.4rem}
.sec-heading{
  font-family:'Cinzel',serif;font-weight:700;
  font-size:clamp(2rem,3.5vw,3rem);color:var(--cream);
  letter-spacing:.05em;margin-bottom:70px;line-height:1.15;
}
.sec-heading em{font-style:italic;color:var(--gold)}

.services-wrap{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
  background:var(--border-r);border:1px solid var(--border-r);
}
.svc{
  background:var(--black2);padding:48px 40px;
  position:relative;overflow:hidden;cursor:none;
  transition:background .4s;
}
.svc::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(139,0,0,.12),transparent 60%);
  opacity:0;transition:opacity .4s;
}
.svc::after{
  content:'';position:absolute;left:0;bottom:0;width:0;height:2px;
  background:linear-gradient(90deg,var(--red-hot),var(--gold));
  box-shadow:0 0 10px var(--red-hot);transition:width .5s ease;
}
.svc:hover{background:var(--black3)}
.svc:hover::before{opacity:1}
.svc:hover::after{width:100%}

.svc-num{
  font-family:'Bebas Neue',sans-serif;font-size:3.5rem;
  color:rgba(139,0,0,.12);line-height:1;margin-bottom:28px;
  transition:color .3s;
}
.svc:hover .svc-num{color:rgba(192,0,26,.25)}
.svc-icon{
  width:40px;height:40px;color:var(--red-hot);margin-bottom:20px;
  transition:transform .4s,color .3s;filter:drop-shadow(0 0 6px var(--red));
}
.svc:hover .svc-icon{transform:scale(1.15);color:var(--gold)}
.svc-name{
  font-family:'Cinzel',serif;font-size:.88rem;font-weight:600;
  color:var(--cream);letter-spacing:.1em;text-transform:uppercase;
  margin-bottom:14px;transition:color .3s;
}
.svc:hover .svc-name{color:var(--gold-lt)}
.svc-desc{font-size:.95rem;font-weight:300;color:var(--text2);line-height:1.85}

/* ─────────────────────────────────────────
   ABOUT / APPROACH
───────────────────────────────────────── */
#about{
  background:var(--black2);
  padding:120px;position:relative;z-index:10;
  overflow:hidden;
}
#about::before{
  content:'CINEMA';position:absolute;right:-60px;top:50%;
  transform:translateY(-50%);
  font-family:'Bebas Neue',sans-serif;font-size:18vw;
  color:rgba(139,0,0,.035);letter-spacing:.1em;pointer-events:none;white-space:nowrap;
}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:100px;align-items:center}
.about-left{}
.about-quote{
  font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;
  font-size:clamp(1.6rem,3vw,2.8rem);
  color:var(--cream);line-height:1.45;margin-bottom:36px;
  border-left:3px solid var(--red-hot);padding-left:32px;
  box-shadow:-3px 0 30px rgba(192,0,26,.2);
}
.about-quote span{color:var(--gold)}
.about-body{
  font-size:1.05rem;font-weight:300;color:var(--text2);
  line-height:1.9;margin-bottom:44px;
}
.about-right{}
.skill-bars{display:flex;flex-direction:column;gap:24px}
.skill-bar{}
.skill-bar-header{
  display:flex;justify-content:space-between;margin-bottom:8px;
}
.skill-bar-name{
  font-family:'Inter',sans-serif;font-size:.65rem;letter-spacing:.2em;
  color:var(--text);text-transform:uppercase;
}
.skill-bar-val{
  font-family:'Bebas Neue',sans-serif;font-size:.9rem;color:var(--gold);
}
.skill-track{height:2px;background:rgba(139,0,0,.2);position:relative}
.skill-fill{
  height:100%;background:linear-gradient(90deg,var(--red),var(--gold));
  box-shadow:0 0 10px var(--red-hot);
  width:0;transition:width 1.4s cubic-bezier(.16,1,.3,1);
}

/* ─────────────────────────────────────────
   PROCESS
───────────────────────────────────────── */
#process{
  background:var(--black);padding:120px;position:relative;z-index:10;
}
.process-steps{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-top:70px}
.proc-step{
  padding:40px 36px;border-left:1px solid var(--border-r);
  position:relative;cursor:none;transition:background .3s;
}
.proc-step:hover{background:var(--black3)}
.proc-step::after{
  content:'';position:absolute;top:0;left:-1px;width:1px;height:0;
  background:var(--red-hot);box-shadow:var(--glow-r);
  transition:height .4s;
}
.proc-step:hover::after{height:100%}
.proc-num{
  font-family:'Bebas Neue',sans-serif;font-size:3rem;
  color:var(--red);opacity:.4;line-height:1;margin-bottom:20px;
  transition:opacity .3s;
}
.proc-step:hover .proc-num{opacity:.8}
.proc-name{
  font-family:'Cinzel',serif;font-size:.8rem;font-weight:600;
  color:var(--cream);letter-spacing:.1em;text-transform:uppercase;
  margin-bottom:12px;
}
.proc-desc{font-size:.9rem;font-weight:300;color:var(--text2);line-height:1.8}
.proc-day{
  margin-top:20px;font-family:'Inter',sans-serif;font-size:.6rem;
  letter-spacing:.2em;color:var(--gold-dim);text-transform:uppercase;
}

/* ─────────────────────────────────────────
   TOOLS
───────────────────────────────────────── */
#tools{
  background:var(--black2);padding:100px 120px;position:relative;z-index:10;
}
.tools-flex{display:flex;flex-wrap:wrap;gap:10px;margin-top:50px}
.tool{
  font-family:'Inter',sans-serif;font-size:.63rem;font-weight:300;
  letter-spacing:.2em;padding:12px 22px;text-transform:uppercase;cursor:none;
  border:1px solid var(--border-r);color:var(--text2);
  transition:all .3s;position:relative;overflow:hidden;
}
.tool::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(139,0,0,.3),rgba(201,168,76,.1));
  transform:scaleX(0);transform-origin:left;transition:transform .35s;
}
.tool:hover{color:var(--gold-lt);border-color:var(--gold-dim)}
.tool:hover::before{transform:scaleX(1)}

/* ─────────────────────────────────────────
   TESTIMONIALS
───────────────────────────────────────── */
#testimonials{
  background:var(--black);padding:120px;position:relative;z-index:10;
}
.testi-row{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1px;background:var(--border-r);margin-top:70px;
}
.tcard{
  background:var(--black2);padding:52px 44px;position:relative;overflow:hidden;
}
.tcard::before{
  content:'"';position:absolute;top:-30px;right:20px;
  font-family:'Cinzel',serif;font-size:10rem;font-weight:900;
  color:var(--red);opacity:.05;line-height:1;pointer-events:none;
}
.tcard-stars{
  display:flex;gap:4px;margin-bottom:22px;
}
.star{
  width:12px;height:12px;color:var(--gold);
}
.tcard-text{
  font-size:1rem;font-weight:300;font-style:italic;
  color:var(--text2);line-height:1.85;margin-bottom:32px;
}
.tcard-author{display:flex;align-items:center;gap:16px}
.tcard-av{
  width:46px;height:46px;border-radius:50%;
  background:linear-gradient(135deg,var(--red-deep),var(--red));
  border:1px solid var(--gold-dim);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cinzel',serif;font-size:.75rem;font-weight:700;color:var(--gold);
}
.tcard-name{
  font-family:'Cinzel',serif;font-size:.78rem;font-weight:600;
  color:var(--cream);letter-spacing:.08em;margin-bottom:3px;
}
.tcard-role{
  font-family:'Inter',sans-serif;font-size:.6rem;letter-spacing:.15em;
  color:var(--text2);text-transform:uppercase;
}

/* ─────────────────────────────────────────
   CONTACT
───────────────────────────────────────── */
#contact{
  background:
    radial-gradient(ellipse 80% 60% at 50% 50%,rgba(90,0,0,.3),transparent 70%),
    var(--black2);
  padding:120px;position:relative;z-index:10;
}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:100px;margin-top:70px;align-items:start}
.contact-pre{
  font-size:1.15rem;font-weight:300;color:var(--text2);line-height:1.9;margin-bottom:52px;
}
.contact-items{display:flex;flex-direction:column;gap:24px}
.ci{
  display:flex;align-items:center;gap:18px;
  font-family:'Inter',sans-serif;font-size:.75rem;letter-spacing:.15em;
  color:var(--text2);text-decoration:none;cursor:none;
  transition:color .3s;text-transform:lowercase;
}
.ci:hover{color:var(--gold)}
.ci-icon{
  width:44px;height:44px;border:1px solid var(--border-r);
  display:flex;align-items:center;justify-content:center;
  color:var(--red-hot);flex-shrink:0;transition:all .3s;
}
.ci:hover .ci-icon{border-color:var(--gold-dim);color:var(--gold);box-shadow:var(--glow-g)}

.cform{display:flex;flex-direction:column;gap:22px}
.fg{position:relative}
.fg label{
  display:block;font-family:'Inter',sans-serif;font-size:.6rem;letter-spacing:.25em;
  color:var(--gold-dim);text-transform:uppercase;margin-bottom:8px;
}
.fg input,.fg textarea,.fg select{
  width:100%;background:rgba(20,8,10,.8);
  border:1px solid var(--border-r);border-bottom:1px solid rgba(139,0,0,.5);
  color:var(--cream);font-family:'Cormorant Garamond',serif;font-size:1rem;
  padding:14px 18px;outline:none;transition:border-color .3s,box-shadow .3s;
  appearance:none;
}
.fg input:focus,.fg textarea:focus,.fg select:focus{
  border-color:var(--gold-dim);box-shadow:0 0 20px rgba(201,168,76,.1),0 4px 0 -1px var(--gold-dim);
}
.fg input::placeholder,.fg textarea::placeholder{color:var(--text2);font-style:italic}
.fg textarea{height:130px;resize:none}
.fg select{color:var(--text2)}
.fg select option{background:var(--black2)}
.csubmit{
  font-family:'Cinzel',serif;font-size:.72rem;letter-spacing:.2em;
  padding:18px;
  background:linear-gradient(135deg,var(--red-deep),var(--red));
  color:var(--gold-bright);border:1px solid var(--red-hot);cursor:none;
  text-transform:uppercase;width:100%;
  transition:all .4s;box-shadow:0 0 20px rgba(139,0,0,.3);
}
.csubmit:hover{
  background:linear-gradient(135deg,var(--red),var(--red-hot));
  box-shadow:var(--glow-r);transform:translateY(-2px);
}

.formMessage{
  background:rgba(76,175,80,.2);
  color:#81c784;
  border:1px solid rgba(76,175,80,.5);
}

.formMessage.error{
  background:rgba(244,67,54,.2);
  color:#ef5350;
  border:1px solid rgba(244,67,54,.5);
}

/* ─────────────────────────────────────────
   FOOTER
───────────────────────────────────────── */
footer{
  background:var(--black);
  border-top:1px solid var(--border-r);
  padding:44px 120px;
  display:flex;align-items:center;justify-content:space-between;
  position:relative;z-index:10;
}
.f-logo{
  font-family:'Cinzel',serif;font-weight:900;font-size:.95rem;
  letter-spacing:.3em;color:var(--gold);
}
.f-logo em{color:var(--red-hot);font-style:normal}
.f-copy{
  font-family:'Inter',sans-serif;font-size:.6rem;letter-spacing:.2em;
  color:var(--text2);text-transform:uppercase;
}
.f-links{display:flex;gap:20px}
.f-links a{
  width:38px;height:38px;border:1px solid var(--border-r);
  display:flex;align-items:center;justify-content:center;
  font-family:'Inter',sans-serif;font-size:.6rem;letter-spacing:.1em;
  color:var(--text2);text-decoration:none;cursor:none;
  transition:all .3s;
}
.f-links a:hover{border-color:var(--gold-dim);color:var(--gold);box-shadow:var(--glow-g)}

/* ─────────────────────────────────────────
   SCROLL REVEAL
───────────────────────────────────────── */
.rv{opacity:0;transform:translateY(36px);transition:opacity .8s ease,transform .8s ease}
.rv.in{opacity:1;transform:none}
.rv-l{opacity:0;transform:translateX(-36px);transition:opacity .8s ease,transform .8s ease}
.rv-l.in{opacity:1;transform:none}
.rv-r{opacity:0;transform:translateX(36px);transition:opacity .8s ease,transform .8s ease}
.rv-r.in{opacity:1;transform:none}

/* ─────────────────────────────────────────
   RESPONSIVE
───────────────────────────────────────── */
@media(max-width:1100px){
  nav,#services,#about,#process,#tools,#testimonials,#contact,footer{padding-left:48px;padding-right:48px}
  .featured-header,.work-hero-info{padding-left:48px;padding-right:48px}
  .hero-content{padding-left:80px;padding-right:80px}
  .hero-stats{right:48px}
  .process-steps{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:900px){
  .nav-links{display:none}
  .hero-content{padding:0 32px 60px}
  .hero-title{font-size:clamp(4rem,16vw,8rem)}
  .hero-stats{position:static;flex-direction:row;padding:0 32px 40px;gap:32px}
  .work-hero{grid-template-columns:1fr}
  .work-hero-visual{aspect-ratio:16/9}
  .work-hero-visual::after{background:linear-gradient(0deg,var(--black2),transparent)}
  .works-grid{grid-template-columns:1fr 1fr}
  .works-grid-b{grid-template-columns:1fr}
  .services-wrap{grid-template-columns:1fr 1fr}
  .about-grid{grid-template-columns:1fr;gap:50px}
  .process-steps{grid-template-columns:1fr 1fr}
  .testi-row{grid-template-columns:1fr}
  .contact-grid{grid-template-columns:1fr;gap:50px}
  footer{flex-direction:column;gap:20px;text-align:center;padding:32px}
  #about::before{display:none}
}
@media(max-width:600px){
  .works-grid{grid-template-columns:1fr}
  .services-wrap{grid-template-columns:1fr}
  .process-steps{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- OVERLAYS -->
<div id="grain"></div>
<div id="vignette"></div>
<div id="scanlines"></div>

<!-- CURSOR -->
<div id="cur"></div>
<div id="cur-ring"></div>

<!-- ══════════════════════════════════════
     NAV
══════════════════════════════════════ -->
<nav id="nav">
  <a href="#hero" class="logo">CROSS<em>.</em>CUT</a>
  <ul class="nav-links">
    <li><a href="#featured">Works</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#contact" class="nav-hire">Hire Me</a>
  <a href="admin.html" class="nav-hire" style="background: linear-gradient(135deg, var(--gold-dim), var(--gold-bright)); color: var(--black); border-color: var(--gold); margin-left: 12px;">Admin</a>
</nav>

<!-- ══════════════════════════════════════
     HERO
══════════════════════════════════════ -->
<section id="hero">
  <div class="hero-film"></div>
  <div class="hero-bar"></div>
  <div class="hero-frames"></div>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <div class="eyebrow-line"></div>
      <span class="eyebrow-text">Available for projects — 2026</span>
      <div class="eyebrow-dot"></div>
    </div>

    <h1 class="hero-title">
      <span class="red-word">VISUAL</span><br>
      <span class="gold-outline">STORY</span><br>
      <span class="red-word">TELLER</span>
    </h1>

    <p class="hero-sub">
      Editor · Director of Photography · <span>Brand Architect</span>
    </p>

    <div class="hero-actions">
      <a href="#featured" class="btn-reel">View My Work</a>
      <a href="#contact" class="btn-works">Start a Project</a>
    </div>
  </div>

  <div class="hero-stats">
    <div class="h-stat">
      <div class="h-stat-num"><span class="count" data-t="10">0</span>+</div>
      <div class="h-stat-lbl">Projects</div>
    </div>
    <div class="h-stat">
      <div class="h-stat-num"><span class="count" data-t="2">0</span>+</div>
      <div class="h-stat-lbl">Years Exp.</div>
    </div>
    <div class="h-stat">
      <div class="h-stat-num"><span class="count" data-t="98">0</span><span>%</span></div>
      <div class="h-stat-lbl">Satisfaction</div>
    </div>
  </div>

  <div class="scroll-ind">
    <span>Scroll</span>
    <div class="scroll-ind-bar"></div>
  </div>
</section>

<!-- ══════════════════════════════════════
     FEATURED WORKS (HOMEPAGE)
══════════════════════════════════════ -->
<section id="featured">

  <div class="featured-header rv">
    <div class="featured-title-block">
      <div class="featured-eyebrow">Selected Works</div>
      <h2 class="featured-heading">Best of the <em>Reel</em></h2>
    </div>
    <a href="#" class="featured-view-all">View All Projects</a>
  </div>

  <!-- BIG HERO WORK -->
  <div class="work-hero rv">
    <div class="work-hero-visual">
      <div class="thumb thumb-1"></div>
      <div class="play-over">
        <div class="play-circle">
          <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        </div>
      </div>
    </div>
    <div class="work-hero-info">
      <div class="work-cat">Featured / Short Film</div>
      <h3 class="work-hero-title">NEE IRNDHAL<br><span>PODHUM</span></h3>
      <p class="work-hero-desc">
        A 22-minute thriller drama  — full edit, color grade, and sound design. Shot in 18 days, edited and dubbed in 20. Screened at Zee5 film festivals.
      </p>
      <div class="work-tags">
        <span class="work-tag">Short Film</span>
        <span class="work-tag">Color Grade</span>
        <span class="work-tag">Sound Mix</span>
        <span class="work-tag">Motion Titles</span>
      </div>
      <a href="https://youtu.be/gzmktE_qmrM?si=rFeI2V0E581ccWfX" class="work-link">Watch the Trailer</a>
    </div>
  </div>

  <!-- GRID ROW 1 -->
  <div class="works-grid rv">

    <div class="work-cell work-cell-mid">
      <div class="work-cell-num">02</div>
      <div class="work-cell-inner">
        <div class="work-cell-thumb t1">
          <div class="thumb-deco">
            <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="0.5">
              <rect x="10" y="10" width="60" height="60"/>
              <rect x="20" y="20" width="40" height="40"/>
              <line x1="10" y1="10" x2="70" y2="70"/><line x1="70" y1="10" x2="10" y2="70"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="work-cell-overlay">
        <div class="cell-cat">Official Teaser</div>
        <div class="cell-title">Glimpse of Danger </div>
        <a href="https://youtu.be/GhPbUyXhbAk?si=8R62QaPStldrZQj9" class="work-link">Watch  Teaser</a>
      </div>
    </div>

    <div class="work-cell work-cell-mid" style="border-right:none">
      <div class="work-cell-num">03</div>
      <div class="work-cell-inner">
        <div class="work-cell-thumb t2">
          <div class="thumb-deco">
            <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="0.5">
              <circle cx="40" cy="40" r="30"/><circle cx="40" cy="40" r="18"/><circle cx="40" cy="40" r="6"/>
              <line x1="40" y1="10" x2="40" y2="70"/><line x1="10" y1="40" x2="70" y2="40"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="work-cell-overlay">
        <div class="cell-cat">Brand Reel</div>
        <div class="cell-title">Dreamsync Production</div>
        <a href="https://www.instagram.com/reel/DRCqzLLCDyS/?utm_source=ig_web_copy_link&igsh=MzRlODBiNWFlZA==" class="work-link">View Reel</a>
      </div>
    </div>

    <div class="work-cell" style="border-right:none">
      <div class="work-cell-num">04</div>
      <div class="work-cell-inner">
        <div class="work-cell-thumb2 t3">
          <div class="thumb-deco">
            <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="0.5">
              <polygon points="40,5 75,65 5,65"/>
              <polygon points="40,20 62,58 18,58"/>
              <line x1="40" y1="5" x2="40" y2="65"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="work-cell-overlay">
        <div class="cell-cat">Graphic Design</div>
        <div class="cell-title">Title Cards / Logo Design</div>
        <a href="images\images.html" class="work-link">View Artwork</a>
      </div>
    </div>

  </div>
<div class="works-grid-c rv">
  

</div>
  <!-- GRID ROW 2 -->
  <div class="works-grid-b rv">

    <div class="work-cell work-cell-wide">
      <div class="work-cell-num">05</div>
      <div class="work-cell-inner">
        <div class="work-cell-thumb t4">
          <div class="thumb-deco">
            <svg viewBox="0 0 160 80" fill="none" stroke="currentColor" stroke-width="0.5">
              <rect x="5" y="5" width="150" height="70"/>
              <rect x="15" y="15" width="130" height="50"/>
              <line x1="5" y1="40" x2="155" y2="40"/>
              <line x1="80" y1="5" x2="80" y2="75"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="work-cell-overlay">
        <div class="cell-cat">Movie Poster</div>
        <div class="cell-title">Nee Irundhal Podhum — POSTER SERIES</div>
        <a href="images\poster.html" class="work-link">View Artwork</a>
      </div>
    </div>

    <div class="work-cell work-cell-mid2" style="border-right:none">
      <div class="work-cell-num">06</div>
      <div class="work-cell-inner">
        <div class="work-cell-thumb t5">
          <div class="thumb-deco">
            <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="0.5">
              <rect x="20" y="15" width="40" height="50" rx="2"/>
              <line x1="28" y1="28" x2="52" y2="28"/>
              <line x1="28" y1="36" x2="44" y2="36"/>
              <circle cx="40" cy="52" r="7"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="work-cell-overlay">
