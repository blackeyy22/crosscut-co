<!-- ══════════════════════════════════════
     CONTACT
══════════════════════════════════════ -->
<section id="contact">
  <div class="sec-label rv">Get In Touch</div>
  <h2 class="sec-heading rv">Let's Make Something <em>Legendary</em></h2>

  <div class="contact-grid">
    <div class="rv-l">
      <p class="contact-pre">
        Have a project in mind? Whether it's a feature film trailer, a viral brand reel, or a logo that needs to command attention — I'm ready to bring your vision to life with cinematic precision.
      </p>
      <div class="contact-items">
        <a href="mailto:robinmohan@yahoo.com" class="ci">
          <div class="ci-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          robinmohan@yahoo.com
        </a>
        <a href="https://instagram.com/crosscut0109" class="ci">
          <div class="ci-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </div>
          @crosscut0109
        </a>
      </div>
    </div>

    <form class="cform rv-r" id="contactForm">
      <div class="fg">
        <label>Your Name</label>
        <input type="text" name="name" placeholder="Your full name" required/>
      </div>
      <div class="fg">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="you@studio.com" required/>
      </div>
      <div class="fg">
        <label>Project Type</label>
        <select name="projectType" required>
          <option value="" disabled selected>Select project type...</option>
          <option>Short Film Editing</option>
          <option>Trailer / Teaser</option>
          <option>Reels & Shorts</option>
          <option>Movie Poster</option>
          <option>Logo Design</option>
          <option>Color Grading</option>
          <option>Full Production Package</option>
        </select>
      </div>
      <div class="fg">
        <label>Estimated Amount (Optional)</label>
        <input type="text" name="amount" placeholder="e.g., ₹5000" />
      </div>
      <div class="fg">
        <label>Your Vision</label>
        <textarea name="message" placeholder="Tell me about your project, timeline, and budget..." required></textarea>
      </div>
      <button type="submit" class="csubmit">Send Message →</button>
      <div id="formMessage" class="formMessage" style="display: none; margin-top: 12px; padding: 12px; border-radius: 6px; text-align: center; font-size: 0.9rem;"></div>
    </form>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="f-logo">CROSS<em>.</em>CUT</div>
  <div class="f-copy">© 2026 CROSS.CUT — All Rights Reserved</div>
  <div class="f-links">
    <a href="https://instagram.com/crosscut0109" target="_blank"> <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
    <a href="mailto:robinmohan@yahoo.com" target="_blank">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </a>
    <a href="https://www.youtube.com/@DreamSync_2" target="_blank">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/>
    <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
</svg>
    </a>
  </div>
</footer>
<!-- ══════════════════════════════════════
     SCRIPTS
══════════════════════════════════════ -->
<script>
/* CURSOR */
const cur = document.getElementById('cur');
const ring = document.getElementById('cur-ring');
let mx=window.innerWidth/2, my=window.innerHeight/2;
let rx=mx, ry=my;

document.addEventListener('mousemove',e=>{
  mx=e.clientX; my=e.clientY;
  cur.style.left=mx+'px'; cur.style.top=my+'px';
});
(function animRing(){
  rx+=(mx-rx)*.13; ry+=(my-ry)*.13;
  ring.style.left=rx+'px'; ring.style.top=ry+'px';
  requestAnimationFrame(animRing);
})();

document.querySelectorAll('a,button,.svc,.work-cell,.work-hero-visual,.tool,.tcard').forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('cur-hover'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('cur-hover'));
});

/* NAV STUCK */
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('stuck',scrollY>60);
});

/* SCROLL REVEAL */
const rvEls = document.querySelectorAll('.rv,.rv-l,.rv-r');
const rvObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('in'); });
},{threshold:.12});
rvEls.forEach(el=>rvObs.observe(el));

/* CONTACT FORM */
document.getElementById('contactForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const form = e.target;
  const formData = {
    name: form.name.value,
    email: form.email.value,
    projectType: form.projectType.value,
    message: form.message.value,
    amount: form.amount.value || 'Contact for quote'
  };

  const messageEl = document.getElementById('formMessage');
  const submitBtn = form.querySelector('.csubmit');
  
  try {
    submitBtn.disabled = true;
    submitBtn.style.opacity = '0.6';
    submitBtn.textContent = 'Sending...';

    const response = await fetch('/api/submit-request', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(formData)
    });

    const data = await response.json();

    if (data.success) {
      messageEl.textContent = '✓ Request submitted successfully! We will review and get back via email, also check the spam folder.';
      messageEl.className = 'formMessage';
      messageEl.style.display = 'block';
      form.reset();
      
      setTimeout(() => {
        messageEl.style.display = 'none';
      }, 5000);
    } else {
      // Show validation errors if available
      const errorMessage = data.error || (data.errors && data.errors.length > 0 
        ? data.errors.join('\n') 
        : 'Submission failed');
      throw new Error(errorMessage);
    }
  } catch (error) {
    const errorText = error.message.replace(/\n/g, ' • ');
    messageEl.innerHTML = '❌ ' + errorText;
    messageEl.className = 'formMessage error';
    messageEl.style.display = 'block';
  } finally {
    submitBtn.disabled = false;
    submitBtn.style.opacity = '1';
    submitBtn.textContent = 'Send Message →';
  }
});


/* COUNTERS */
document.querySelectorAll('.count').forEach(el=>{
  const obs = new IntersectionObserver(([entry])=>{
    if(!entry.isIntersecting) return;
    const target=+el.dataset.t, dur=1600, start=performance.now();
    (function tick(now){
      const p=Math.min((now-start)/dur,1);
      const ease=1-Math.pow(1-p,3);
      el.textContent=Math.floor(ease*target);
      if(p<1) requestAnimationFrame(tick); else el.textContent=target;
    })(start);
    obs.disconnect();
  },{threshold:.5});
  obs.observe(el);
});

/* SKILL BARS */
document.querySelectorAll('.skill-fill').forEach(el=>{
  const obs = new IntersectionObserver(([entry])=>{
    if(!entry.isIntersecting) return;
    el.style.width = el.dataset.w + '%';
    obs.disconnect();
  },{threshold:.3});
  obs.observe(el);
});

/* FORM SUBMIT */
function sendMsg(btn){
  const form = btn.closest('form');
  if(!form.checkValidity()) {
    alert('Please fill in all required fields');
    return;
  }
  btn.textContent='Sending...';
  btn.style.opacity='.6';
  btn.disabled = true;
}

/* SMOOTH SCROLL */
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    e.preventDefault();
    const t=document.querySelector(a.getAttribute('href'));
    if(t) t.scrollIntoView({behavior:'smooth',block:'start'});
  });
});
</script>
</body>
</html>
